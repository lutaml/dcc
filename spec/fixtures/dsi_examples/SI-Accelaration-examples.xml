			<si:label>sensitivity phase</si:label> <!-- label zur einheitlichen Erkennbarkeit der Messgröße-->
			<si:value>0.2</si:value>
			<si:unit>\degree</si:unit>
			<si:expandedUnc>
				<si:uncertainty>0.5</si:uncertainty>
				<si:coverageFactor>2</si:coverageFactor>
				<si:coverageProbability>0.95</si:coverageProbability>
				<si:distribution>normal</si:distribution>
			</si:expandedUnc>
		</si:real>
	</siTest:testData>
	
	
	<siTest:testData id="DCC_ACCELERATION_9_Betrag">
		<!-- Ladungsverstärker  (V/pC) -->
		<!-- (Betrag und Phase )-->
		<si:real>
			<si:label>sensitivity magnitude</si:label> <!-- label zur einheitlichen Erkennbarkeit der Messgröße-->
			<si:value>10.001</si:value>
			<si:unit>\volt\pico\coulomb\tothe{-1}</si:unit>
			<si:expandedUnc>
				<si:uncertainty>0.03</si:uncertainty>
				<si:coverageFactor>2</si:coverageFactor>
				<si:coverageProbability>0.95</si:coverageProbability>
				<si:distribution>normal</si:distribution>
			</si:expandedUnc>
		</si:real>
	</siTest:testData>
	
	
	<siTest:testData id="DCC_ACCELERATION_9_Phase">
		<si:real>
			<si:label>sensitivity phase</si:label> <!-- label zur einheitlichen Erkennbarkeit der Messgröße-->
			<si:value>0.2</si:value>
