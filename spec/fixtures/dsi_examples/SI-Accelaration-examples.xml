	<siTest:metaData>
		<siTest:testDescription>D-SI examples supporting the implementation of DCCs for acceleration measurements</siTest:testDescription>
	</siTest:metaData>
	
	<siTest:testData id="DCC_ACCELERATION_1">
		<!-- Frequenz 6,3 Hz  -->
		<si:real>
			<si:label>frequency</si:label> <!-- label zur einheitlichen Erkennbarkeit der Messgröße-->
			<si:value>6.3</si:value>
			<si:unit>\hertz</si:unit>
			<si:expandedUnc>
				<si:uncertainty>0.50</si:uncertainty>
				<si:coverageFactor>2</si:coverageFactor>
				<si:coverageProbability>0.95</si:coverageProbability>
				<si:distribution>normal</si:distribution>
			</si:expandedUnc>
		</si:real>
	</siTest:testData>
	
	
	<siTest:testData id="DCC_ACCELERATION_2">
		<!-- Kreisfrequenz 39,58 s^(-1) -->
		<si:real>
			<si:label>angular frequency</si:label> <!-- label zur einheitlichen Erkennbarkeit der Messgröße-->
			<si:value>39.58</si:value>
			<si:unit>\second\tothe{-1}</si:unit>
			<si:expandedUnc>
				<si:uncertainty>3.14</si:uncertainty>
				<si:coverageFactor>2</si:coverageFactor>
				<si:coverageProbability>0.95</si:coverageProbability>
				<si:distribution>normal</si:distribution>
			</si:expandedUnc>
		</si:real>
	</siTest:testData>
	
	
	<siTest:testData id="DCC_ACCELERATION_3">
		<!-- Beschleunigungsamplitude (m/s^2) -->
		<!-- z.B. Anregungsbeschleunigung  -->
		<si:real>
			<si:label>accelaration amplitude</si:label> <!-- label zur einheitlichen Erkennbarkeit der Messgröße-->
			<si:value>98.5</si:value>
			<si:unit>\metre\second\tothe{-2}</si:unit>
			<si:expandedUnc>
				<si:uncertainty>0.50</si:uncertainty>
				<si:coverageFactor>2</si:coverageFactor>
				<si:coverageProbability>0.95</si:coverageProbability>
				<si:distribution>normal</si:distribution>
			</si:expandedUnc>
		</si:real>
	</siTest:testData>
	
	
	<siTest:testData id="DCC_ACCELERATION_4">
		<!-- Ladungsamplitude (pC)-->
		<si:real>
			<si:label>charge amplitude</si:label> <!-- label zur einheitlichen Erkennbarkeit der Messgröße-->
			<si:value>12.8</si:value>
			<si:unit>\pico\coulomb</si:unit>
			<si:expandedUnc>
				<si:uncertainty>0.050</si:uncertainty>
				<si:coverageFactor>2</si:coverageFactor>
				<si:coverageProbability>0.95</si:coverageProbability>
				<si:distribution>normal</si:distribution>
			</si:expandedUnc>
		</si:real>
	</siTest:testData>
	
	
	<siTest:testData id="DCC_ACCELERATION_5">
		<!-- Spannungsamplitude (V)-->
		<si:real>
			<si:label>voltage amplitude</si:label> <!-- label zur einheitlichen Erkennbarkeit der Messgröße-->
			<si:value>10.8</si:value>
			<si:unit>\milli\volt</si:unit>
			<si:expandedUnc>
				<si:uncertainty>0.054</si:uncertainty>
				<si:coverageFactor>2</si:coverageFactor>
				<si:coverageProbability>0.95</si:coverageProbability>
				<si:distribution>normal</si:distribution>
			</si:expandedUnc>
		</si:real>
	</siTest:testData>
	
	
	<siTest:testData id="DCC_ACCELERATION_6">
		<!-- Beschleunigungsspitzenwert (Stoß) (pC) -->
		<si:real>
			<si:label>peak value</si:label> <!-- label zur einheitlichen Erkennbarkeit der Messgröße-->
			<si:value>12.8</si:value>
			<si:unit>\pico\coulomb</si:unit>
			<si:expandedUnc>
				<si:uncertainty>0.050</si:uncertainty>
				<si:coverageFactor>2</si:coverageFactor>
				<si:coverageProbability>0.95</si:coverageProbability>
				<si:distribution>normal</si:distribution>
			</si:expandedUnc>
		</si:real>
	</siTest:testData>
	
	<!-- Andere Spitzenwerte entsprechend mit angepassten <si:unit> Feldern -->
	
	<siTest:testData id="DCC_ACCELERATION_7">
		<!-- Aufnehmer: Ladungsempfindlichkeit (pC/(m/s^2))-->
		<!-- (nur Betrag) )-->
		<si:real>
			<si:label>sensitivity magnitude</si:label> <!-- label zur einheitlichen Erkennbarkeit der Messgröße-->
			<si:value>0.128</si:value>
			<si:unit>\pico\coulomb\second\tothe{2}\metre\tothe{-1}</si:unit>
			<si:expandedUnc>
				<si:uncertainty>0.0007</si:uncertainty>
				<si:coverageFactor>2</si:coverageFactor>
				<si:coverageProbability>0.95</si:coverageProbability>
				<si:distribution>normal</si:distribution>
			</si:expandedUnc>
		</si:real>
	</siTest:testData>
	
	
	<siTest:testData id="DCC_ACCELERATION_8_Betrag">
		<!-- Aufnehmer: Spannungsempfindlichkeit (V/(m/s^2)) -->
		<!-- (Betrag und Phase )-->
		<si:real>
			<si:label>sensitivity magnitude</si:label> <!-- label zur einheitlichen Erkennbarkeit der Messgröße-->
			<si:value>10.83</si:value>
			<si:unit>\milli\volt\second\tothe{2}\metre\tothe{-1}</si:unit>
			<si:expandedUnc>
				<si:uncertainty>0.11</si:uncertainty>
				<si:coverageFactor>2</si:coverageFactor>
				<si:coverageProbability>0.95</si:coverageProbability>
				<si:distribution>normal</si:distribution>
			</si:expandedUnc>
		</si:real>
	</siTest:testData>
	
	
	<siTest:testData id="DCC_ACCELERATION_8_Phase">
