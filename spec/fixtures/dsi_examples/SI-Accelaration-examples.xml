		<!-- Brückenverstärker V/(mV/V) -->
		<!-- (Betrag und Phase ) -->
		<si:real>
			<si:label>sensitivity magnitude</si:label> <!-- label zur einheitlichen Erkennbarkeit der Messgröße-->
